# Streamlit Secrets 配置模板
# ============================================
# 使用方法：
#   1. 复制本文件为同目录下的 secrets.toml
#         cp secrets.toml.example secrets.toml
#   2. 修改下面的 password 为你想要的访问密码
#   3. secrets.toml 已被 .gitignore 忽略，不会上传到 GitHub
#
# 部署到 Streamlit Cloud 时：
#   无需上传本文件，直接在应用后台 "Settings -> Secrets" 中
#   粘贴下面这一行并填上你的密码即可。

password = "请改成你的访问密码"
